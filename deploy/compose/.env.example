# Copy to .env and replace every REPLACE_* value before starting Compose.
TOKENSEA_ENV=prod
TOKENSEA_CONSOLE_PORT=39210
TOKENSEA_CONTROL_PORT=39211
TOKENSEA_GATEWAY_PORT=39212
TOKENSEA_POSTGRES_PORT=39213
TOKENSEA_REDIS_PORT=39214
TOKENSEA_PROMETHEUS_PORT=39215
TOKENSEA_GRAFANA_PORT=39216
TOKENSEA_RUNTIME_CORE_PORT=39218

TOKENSEA_DB_NAME=tokensea
TOKENSEA_DB_USER=tokensea
TOKENSEA_DB_PASSWORD=REPLACE_WITH_RANDOM_DATABASE_PASSWORD
TOKENSEA_REDIS_PASSWORD=REPLACE_WITH_URL_SAFE_RANDOM_REDIS_PASSWORD
TOKENSEA_DB_URL=jdbc:postgresql://tokensea-postgres:5432/tokensea
TOKENSEA_JWT_SECRET=REPLACE_WITH_RANDOM_VALUE_AT_LEAST_32_BYTES
TOKENSEA_CRYPTO_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY
TOKENSEA_RUNTIME_CORE_KEY=REPLACE_WITH_RANDOM_RUNTIME_MASTER_KEY
TOKENSEA_BOOTSTRAP_TOKEN=REPLACE_WITH_ONE_TIME_RANDOM_BOOTSTRAP_TOKEN
TOKENSEA_BUDGET_CURRENCY=CNY
TOKENSEA_RUNTIME_CORE_IMAGE=ghcr.io/berriai/litellm:v1.91.0

# Comma-separated browser origins. Wildcards are intentionally unsupported.
TOKENSEA_CORS_ALLOWED_ORIGINS=http://localhost:39210
# Private provider hosts are rejected unless their exact hostname is listed here.
# Exact comma-separated provider API hostnames. Empty means the runtime is denied all egress.
TOKENSEA_ALLOWED_EGRESS_HOSTS=
# Add non-standard provider TLS/HTTP ports explicitly when required.
TOKENSEA_EGRESS_ALLOWED_PORTS=80,443
